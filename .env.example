# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/mac_mini_tracker"

# ─── B&H Photo ───────────────────────────────────────────────────────────────
# Full URL to the exact B&H product page for APZ1VMM77AC
# Example: https://www.bhphotovideo.com/c/product/1866887-REG/apple_z1vm_mm77_ac_mac_mini_m4_pro.html
BH_PRODUCT_URL=""

# ─── Best Buy ─────────────────────────────────────────────────────────────────
# Optional. Get an API key at https://developer.bestbuy.com/
# Without this key, the Best Buy connector returns UNKNOWN.
BESTBUY_API_KEY=""

# ─── Notifications: SMTP email ────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
ALERT_EMAIL_TO=""

# ─── Notifications: Webhook (optional) ───────────────────────────────────────
# POST payload: { text, result } — compatible with Slack incoming webhooks
ALERT_WEBHOOK_URL=""

# ─── Feature flags ───────────────────────────────────────────────────────────
# Set to "true" to enable experimental Playwright-based Apple scraping
# (not yet implemented; reserved for future use)
FEATURE_APPLE_PLAYWRIGHT="false"
